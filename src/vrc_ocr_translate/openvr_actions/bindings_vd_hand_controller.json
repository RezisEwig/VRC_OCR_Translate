{
  "action_manifest_version": 0,
  "bindings": {
    "/actions/translation": {
      "sources": [
        {
          "inputs": {"click": {"output": "/actions/translation/in/translate"}},
          "mode": "button",
          "parameters": {"click_activate_threshold": "0.65", "click_deactivate_threshold": "0.55"},
          "path": "/user/hand/left/input/trigger"
        },
        {
          "inputs": {"click": {"output": "/actions/translation/in/clear"}},
          "mode": "button",
          "parameters": {"click_activate_threshold": "0.65", "click_deactivate_threshold": "0.55"},
          "path": "/user/hand/left/input/grip"
        }
      ]
    }
  },
  "controller_type": "vd_hand_controller",
  "description": "VRC OCR Translate bindings for Virtual Desktop controllers",
  "name": "VRC OCR Translate"
}

{
  "action_manifest_version": 0,
  "bindings": {
    "/actions/translation": {
      "sources": [
        {"inputs": {"click": {"output": "/actions/translation/in/translate"}}, "mode": "button", "path": "/user/hand/left/input/trigger"},
        {"inputs": {"click": {"output": "/actions/translation/in/clear"}}, "mode": "button", "path": "/user/hand/left/input/grip"}
      ]
    }
  },
  "controller_type": "knuckles",
  "description": "VRC OCR Translate bindings for Index controllers",
  "name": "VRC OCR Translate"
}
